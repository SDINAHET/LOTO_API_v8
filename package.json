  "scripts": {
    "test": "echo \"No test specified\"",
    "start:back": "mvn spring-boot:run",
    "lint": "eslint .",
    "html:check": "htmlhint src/",
    "test:e2e": "playwright test",
    "test:report": "playwright test --reporter=html",
    "test:full": "start-server-and-test start:back http://localhost:8082 test:e2e",
