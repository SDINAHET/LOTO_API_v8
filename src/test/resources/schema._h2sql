DROP TABLE IF EXISTS ticket_gains;
DROP TABLE IF EXISTS tickets;
DROP TABLE IF EXISTS users;
DROP TABLE IF EXISTS refresh_tokens;

-- =====================
-- TABLE USERS
-- =====================
CREATE TABLE users (
    id VARCHAR(255) NOT NULL,
    first_name VARCHAR(255) NOT NULL,
    last_name VARCHAR(255) NOT NULL,
    email VARCHAR(255) NOT NULL,
    password VARCHAR(255) NOT NULL,
    is_admin BOOLEAN DEFAULT FALSE NOT NULL,
    created_at VARCHAR(255),
    updated_at VARCHAR(255),
    PRIMARY KEY (id),
    UNIQUE (email)
);

-- =====================
-- TABLE TICKETS
-- =====================
CREATE TABLE tickets (
    id VARCHAR(255) NOT NULL,
    numbers VARCHAR(255) NOT NULL,
    lucky_number INT NOT NULL,
    draw_date VARCHAR(255) NOT NULL,
    draw_day VARCHAR(255),
    created_at VARCHAR(255) NOT NULL,
    updated_at VARCHAR(255),
    user_id VARCHAR(255) NOT NULL,
    PRIMARY KEY (id),
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
);

-- =====================
-- TABLE TICKET_GAINS
-- =====================
CREATE TABLE ticket_gains (
    id VARCHAR(255) NOT NULL,
    ticket_id VARCHAR(255) NOT NULL,
    matching_numbers INT NOT NULL,
    lucky_number_match BOOLEAN NOT NULL,
    gain_amount REAL NOT NULL,
    PRIMARY KEY (id),
    FOREIGN KEY (ticket_id) REFERENCES tickets(id) ON DELETE CASCADE
);

-- =====================
-- TABLE REFRESH TOKENS
-- =====================
CREATE TABLE refresh_tokens (
    id VARCHAR(255) NOT NULL,
    user_id VARCHAR(255) NOT NULL,
    token_hash VARCHAR(255) NOT NULL,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP NOT NULL,
    expires_at TIMESTAMP NOT NULL,
    revoked_at TIMESTAMP,
    PRIMARY KEY (id),
    UNIQUE (token_hash),
    FOREIGN KEY (user_id) REFERENCES users(id) ON DELETE CASCADE
);
